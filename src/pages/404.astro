---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="404 - Page Not Found"
    description="The page you are looking for does not exist."
>
    <div
        class="min-h-[80vh] flex flex-col items-center justify-center section-padding relative z-10 text-center"
    >
        <span
            class="font-mono text-sm text-primary-500 tracking-wider mb-4 block"
            >ERROR 404</span
        >
        <h1
            class="font-heading text-8xl md:text-9xl font-bold mb-4 tracking-tighter"
        >
            <span class="text-gradient-warm">404</span>
        </h1>
        <h2
            class="text-2xl md:text-3xl font-heading font-semibold text-neutral-800 dark:text-neutral-200 mb-6"
        >
            Transmission Lost
        </h2>
        <p
            class="text-neutral-500 dark:text-neutral-400 max-w-md mx-auto mb-10 text-[15px] leading-relaxed"
        >
            The server could not locate the requested resource. The pod might
            have been scaled down or the route does not exist.
        </p>
        <a href="/" class="btn-primary inline-flex">
            Return to Base
            <svg class="w-4 h-4 ml-2" viewBox="0 0 20 20" fill="currentColor">
                <path
                    fill-rule="evenodd"
                    d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                    clip-rule="evenodd"></path>
            </svg>
        </a>

        <!-- Decorative bg elements -->
        <div
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-red-500/[0.04] dark:bg-red-500/[0.02] rounded-full blur-[150px] pointer-events-none -z-10"
        >
        </div>
    </div>
</Layout>
