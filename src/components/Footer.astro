---
const currentYear = new Date().getFullYear();
---

<footer
    class="relative border-t border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-950"
>
    <div class="mx-auto max-w-7xl section-padding py-16">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
            <!-- Brand -->
            <div class="md:col-span-2">
                <div class="flex items-center gap-3 mb-4">
                    <div
                        class="w-10 h-10 relative bg-primary-500 rounded-lg p-1"
                    >
                        <img
                            src="/logo.webp"
                            alt="akash"
                            class="w-full h-full rounded-md object-contain"
                        />
                    </div>
                    <div>
                        <span class="font-heading font-bold text-lg"
                            >akash<span class="text-primary-500">.</span></span
                        >
                        <span
                            class="block text-xs font-mono text-neutral-500 -mt-1"
                            >cloud engineer</span
                        >
                    </div>
                </div>
                <p
                    class="text-neutral-500 dark:text-neutral-400 max-w-sm leading-relaxed"
                >
                    Just a cloud engineer who loves automating things and
                    building infrastructure that doesn't break at 3am. Thanks
                    for visiting my corner of the internet ✌️
                </p>
            </div>

            <!-- Quick Links -->
            <div>
                <h4
                    class="font-heading font-semibold text-sm uppercase tracking-wider text-neutral-400 mb-4"
                >
                    Navigate
                </h4>
                <ul class="space-y-3">
                    <li>
                        <a
                            href="/"
                            class="text-neutral-600 dark:text-neutral-400 hover:text-primary-500 transition-colors duration-300"
                            >Home</a
                        >
                    </li>
                    <li>
                        <a
                            href="/about"
                            class="text-neutral-600 dark:text-neutral-400 hover:text-primary-500 transition-colors duration-300"
                            >About</a
                        >
                    </li>
                    <li>
                        <a
                            href="/projects"
                            class="text-neutral-600 dark:text-neutral-400 hover:text-primary-500 transition-colors duration-300"
                            >Projects</a
                        >
                    </li>
                    <li>
                        <a
                            href="/contact"
                            class="text-neutral-600 dark:text-neutral-400 hover:text-primary-500 transition-colors duration-300"
                            >Contact</a
                        >
                    </li>
                </ul>
            </div>

            <!-- Connect -->
            <div>
                <h4
                    class="font-heading font-semibold text-sm uppercase tracking-wider text-neutral-400 mb-4"
                >
                    Connect
                </h4>
                <ul class="space-y-3">
                    <li>
                        <a
                            href="https://github.com/Akashnsk1"
                            target="_blank"
                            rel="noopener"
                            class="text-neutral-600 dark:text-neutral-400 hover:text-primary-500 transition-colors duration-300"
                            >GitHub</a
                        >
                    </li>
                    <li>
                        <a
                            href="https://www.linkedin.com/in/akash-kshirasagar?utm_source=share&utm_campaign=share_via&utm_content=profile&utm_medium=android_app"
                            target="_blank"
                            rel="noopener"
                            class="text-neutral-600 dark:text-neutral-400 hover:text-primary-500 transition-colors duration-300"
                            >LinkedIn</a
                        >
                    </li>
                </ul>
            </div>
        </div>

        <!-- Bottom bar -->
        <div
            class="mt-12 pt-8 border-t border-neutral-200 dark:border-neutral-800 flex flex-col sm:flex-row justify-between items-center gap-4"
        >
            <p class="text-sm text-neutral-500">
                © {currentYear} Akash. Crafted with precision.
            </p>
            <div class="flex items-center gap-2 text-sm text-neutral-500">
                <span
                    class="w-2 h-2 rounded-full bg-accent-500 animate-pulse-subtle"
                ></span>
                Available for opportunities
            </div>
        </div>
    </div>
</footer>
